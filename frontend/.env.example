# ── Supabase ────────────────────────────────────────────────────────────
# Copy this file to `.env` (same folder) and fill in your project's values.
# Find them in the Supabase dashboard → Project Settings → API.
#
# The anon / "publishable" key is SAFE to ship in the frontend — Row-Level
# Security in the database is what protects your data, not the key.
#
# ⚠️  NEVER put the service_role / "secret" key in this file or anywhere in the
#     frontend. It belongs only in the Edge Function secrets (see SUPABASE_SETUP.md).

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
